<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Runtime permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Exact alarm scheduling — granted for task/calendar apps -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Fallback for older devices -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Re-schedule alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Allow reminders to fire during Doze -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".TaskTrackerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskTracker"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TaskTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Transparent activity that shows the status-update sheet -->
        <activity
            android:name=".ui.statusupdate.StatusUpdateActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.TaskTracker.Transparent" />

        <!-- Fires on alarm to post a notification -->
        <receiver
            android:name=".notification.ReminderReceiver"
            android:exported="false" />

        <!-- Handles "Mark done" from notification -->
        <receiver
            android:name=".notification.MarkDoneReceiver"
            android:exported="false" />

        <!-- Re-schedules alarms after reboot / app update -->
        <receiver
            android:name=".notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
